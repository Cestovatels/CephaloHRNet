!assets/*.pt.keep

# ── Training outputs ──────────────────────────────────────────────────
runs/

# ── Jupyter ───────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── IDEs ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Misc ──────────────────────────────────────────────────────────────
read.txt
*.log
*.tmp
