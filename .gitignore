# ── Virtual environments ──────────────────────────────────────────────
Cepha-env/
venv/
env/
.venv/
*.egg-info/

# ── Python cache ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── Dataset (too large for git) ───────────────────────────────────────
Dataset/
data/raw/

# ── Model weights & checkpoints ───────────────────────────────────────
*.pt
*.pth
*.ckpt
*.pkl
